# ----- Server -----
# Port the API/server listens on
PORT=4000

# Database connection.
# Default: local SQLite file (zero config, great for getting started / small hosting).
DATABASE_URL="file:./dev.db"
# To use PostgreSQL instead, change provider in server/prisma/schema.prisma to "postgresql"
# and set, e.g.:
# DATABASE_URL="postgresql://user:password@host:5432/worksi?schema=public"

# Where uploaded resumes are stored (relative to server/)
UPLOAD_DIR=uploads
# Max resume size in MB
MAX_UPLOAD_MB=5

# Comma separated origins allowed by CORS in dev (the Vite dev server)
CORS_ORIGIN=http://localhost:5173

# Simple admin protection for the applications dashboard (Basic auth-ish token)
ADMIN_TOKEN=change-me-in-production

# Optional: email notifications on new application (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# ----- Client (build time) -----
# Base URL the frontend uses to reach the API. Leave empty to use same-origin "/api".
VITE_API_URL=
